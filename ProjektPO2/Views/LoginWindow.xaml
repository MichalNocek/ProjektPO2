<Window x:Class="ProjektPO2.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TestPortal — logowanie" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        FontFamily="{StaticResource UiFont}" Background="{StaticResource Bg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- ===== STRONA MARKI ===== -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1E40AF" Offset="0" />
                    <GradientStop Color="#FF2563EB" Offset="0.55" />
                    <GradientStop Color="#FF3B82F6" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Border Width="260" Height="260" CornerRadius="40" BorderBrush="#33FFFFFF" BorderThickness="1.5"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-70,-60,0" />
            <Border Width="170" Height="170" CornerRadius="34" BorderBrush="#22FFFFFF" BorderThickness="1.5"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-50,0,0,40" />

            <Grid Margin="52,48">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="11" Background="#33FFFFFF">
                        <TextBlock Text="🎓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="TestPortal" Foreground="White" FontSize="19" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="11,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Foreground="White" FontSize="34" FontWeight="Bold" TextWrapping="Wrap"
                               LineHeight="40" Text="Testy i sprawdziany w jednym miejscu." Margin="0,0,0,16" />
                    <TextBlock Foreground="#DDFFFFFF" FontSize="15" TextWrapping="Wrap" MaxWidth="380"
                               HorizontalAlignment="Left" LineHeight="22" Margin="0,0,0,36"
                               Text="Twórz testy, przydzielaj je grupom uczniów i śledź wyniki — albo rozwiązuj zadania krok po kroku." />
                    <StackPanel x:Name="Features" />
                </StackPanel>

                <TextBlock Grid.Row="2" Foreground="#A0FFFFFF" FontSize="12.5"
                           Text="© 2026 TestPortal · wersja demonstracyjna" />
            </Grid>
        </Grid>

        <!-- ===== STRONA FORMULARZA ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="360" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">

                <TextBlock Text="Witaj w TestPortal" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Text}" />
                <TextBlock Text="Zaloguj się lub utwórz nowe konto." Style="{StaticResource Sub}" Margin="0,4,0,22" />

                <!-- przełącznik trybu -->
                <Border Background="{StaticResource Surface3}" CornerRadius="14" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabLogin"    Grid.Column="0" Content="Zaloguj się" Height="48"
                                Style="{StaticResource RoleTab}" Click="Mode_Click" Tag="login" />
                        <Button x:Name="TabRegister" Grid.Column="1" Content="Zarejestruj" Height="48"
                                Style="{StaticResource RoleTab}" Click="Mode_Click" Tag="register" />
                    </Grid>
                </Border>

                <!-- ===== PANEL LOGOWANIA ===== -->
                <StackPanel x:Name="LoginPanel" Margin="0,22,0,0">
                    <TextBlock Text="Login" Style="{StaticResource Label}" />
                    <TextBox x:Name="LoginBox" Height="44" />

                    <TextBlock Text="Hasło" Style="{StaticResource Label}" Margin="0,14,0,6" />
                    <PasswordBox x:Name="PassBox" Height="44" />

                    <TextBlock x:Name="LoginError" Foreground="{StaticResource Danger}" FontSize="13"
                               Visibility="Collapsed" TextWrapping="Wrap" Margin="0,10,0,0" />

                    <Button Content="Zaloguj się  →" Style="{StaticResource PrimaryButton}"
                            Height="50" FontSize="16" Margin="0,22,0,0" Click="Login_Click" />

                    <TextBlock Text="Demo: m.dabrowski / demo1234 (nauczyciel)" Foreground="{StaticResource Muted}"
                               FontSize="12" TextAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock Text="Demo: anna.k / demo1234 (uczeń)" Foreground="{StaticResource Muted}"
                               FontSize="12" TextAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- ===== PANEL REJESTRACJI ===== -->
                <StackPanel x:Name="RegisterPanel" Margin="0,22,0,0" Visibility="Collapsed">
                    <TextBlock Text="Typ konta" Style="{StaticResource Label}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,14">
                        <RadioButton x:Name="RegRoleStudent" Content="Uczeń" IsChecked="True"
                                     GroupName="RegRole" Foreground="{StaticResource Text}"
                                     VerticalContentAlignment="Center" Margin="0,0,24,0" />
                        <RadioButton x:Name="RegRoleTeacher" Content="Nauczyciel"
                                     GroupName="RegRole" Foreground="{StaticResource Text}"
                                     VerticalContentAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Imię" Style="{StaticResource Label}" />
                            <TextBox x:Name="RegFirstName" Height="44" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Nazwisko" Style="{StaticResource Label}" />
                            <TextBox x:Name="RegLastName" Height="44" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Login" Style="{StaticResource Label}" Margin="0,14,0,6" />
                    <TextBox x:Name="RegLogin" Height="44" />

                    <TextBlock Text="Hasło" Style="{StaticResource Label}" Margin="0,14,0,6" />
                    <PasswordBox x:Name="RegPass" Height="44" />

                    <TextBlock Text="Potwierdź hasło" Style="{StaticResource Label}" Margin="0,14,0,6" />
                    <PasswordBox x:Name="RegPassConfirm" Height="44" />

                    <TextBlock x:Name="RegError" Foreground="{StaticResource Danger}" FontSize="13"
                               Visibility="Collapsed" TextWrapping="Wrap" Margin="0,10,0,0" />

                    <Button Content="Zarejestruj  →" Style="{StaticResource PrimaryButton}"
                            Height="50" FontSize="16" Margin="0,22,0,0" Click="Register_Click" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
