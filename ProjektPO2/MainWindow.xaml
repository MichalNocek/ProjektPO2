<Window x:Class="ProjektPO2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TestPortal" Height="760" Width="1180"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="900"
        FontFamily="{StaticResource UiFont}" Background="{StaticResource Bg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="256" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== PASEK BOCZNY ===== -->
        <Border x:Name="Sidebar" Grid.Column="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <Grid Margin="16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6,0,18">
                    <Border Width="38" Height="38" CornerRadius="11" Background="{StaticResource Primary}"
                            Effect="{StaticResource PrimaryShadow}">
                        <TextBlock Text="🎓" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="TestPortal" FontSize="17" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="11,0,0,0" />
                </StackPanel>

                <StackPanel x:Name="NavPanel" Grid.Row="1" />

                <Border Grid.Row="2" Background="{StaticResource Surface2}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="14" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="UserAvatar" Grid.Column="0" Width="38" Height="38"
                                CornerRadius="19" Background="{StaticResource Primary}">
                            <TextBlock x:Name="UserInitials" Foreground="White" FontWeight="Bold"
                                       FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="11,0,0,0">
                            <TextBlock x:Name="UserName" FontWeight="Bold" FontSize="13.5"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="UserRole" Style="{StaticResource Sub}" FontSize="12" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Wyloguj" FontSize="12.5" Height="34" Padding="12,0"
                                Style="{StaticResource GhostButton}" ToolTip="Wyloguj się"
                                Click="Logout_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== TREŚĆ ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TopBar" Grid.Row="0" Margin="36,22,36,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="PageTitle" Style="{StaticResource H1}" />
                    <TextBlock x:Name="PageSub"   Style="{StaticResource Sub}" FontSize="14" Margin="0,2,0,0" />
                </StackPanel>
                <ContentControl x:Name="TopBarActions" Grid.Column="1" VerticalAlignment="Center" />
            </Grid>

            <ScrollViewer x:Name="ContentScroll" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto" Padding="36,8,36,36">
                <ContentControl x:Name="ContentArea" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
